// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

// ─── ADMIN ────────────────────────────────────────────────────────────────────

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  otpTokens      OtpToken[]
  refreshTokens  RefreshToken[]

  @@map("admin")
}

// ─── OTP TOKEN ────────────────────────────────────────────────────────────────

model OtpToken {
  id        String   @id @default(cuid())
  adminId   String   @map("admin_id")
  codeHash  String   @map("code_hash")   // bcrypt hash of 6-digit OTP
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("otp_token")
}

// ─── REFRESH TOKEN ───────────────────────────────────────────────────────────

model RefreshToken {
  id        String    @id @default(cuid())
  adminId   String    @map("admin_id")
  tokenHash String    @map("token_hash")  // sha256 hash of the actual token
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("refresh_token")
}

enum SkillMode {
  code
  terminal
}

model Skill {
  id         String    @id @default(cuid())
  name       String
  icon       String
  file_name  String
  lang       String    @unique
  color      String
  mode       SkillMode
  code       Json?     // String[]        — present only when mode = code
  commands   Json?     // TerminalLine[]  — present only when mode = terminal
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
}

model Portfolio_item {
  id             String   @id @default(uuid())
  site_name      String
  site_role      String
  site_url       String
  site_image_url String
  use_tech       Json
  description    String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
 
  @@map("portfolio_items")
}

model ContactMessage {
  id         String   @id @default(cuid())
  full_name  String
  email      String
  message    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
 
  @@map("contact_messages")
}